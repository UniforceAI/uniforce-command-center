# ============================================
# CONFIGURAÇÃO DE AMBIENTE - UNIFORCE
# ============================================
# Este é um arquivo de TEMPLATE - NÃO contém credenciais reais
# Copie este arquivo para .env e preencha com as credenciais reais
#
# COMANDO: cp .env.example .env
#
# IMPORTANTE: O arquivo .env está no .gitignore e NUNCA deve ser commitado!
# ============================================

# ============================================
# n8n API Configuration
# ============================================
# URL base da API do n8n (atrás do Cloudflare Access)
N8N_API_URL=https://api.uniforce.com.br

# API Key do n8n (Bearer token para autenticação)
# Obter em: n8n Settings → API
N8N_API_KEY=

# IDs dos workflows principais (separados por vírgula)
WORKFLOW_ID=

# ============================================
# Cloudflare Access Service Token
# ============================================
# Service Token para bypass do Cloudflare Access
# Obter em: Cloudflare Dashboard → Zero Trust → Access → Service Auth → Create Service Token
# IMPORTANTE: Estas credenciais permitem acesso direto sem autenticação interativa

# Client ID do Service Token (formato: xxx.access)
CF_CLIENT_ID=

# Client Secret do Service Token
CF_CLIENT_SECRET=

# ============================================
# Supabase Project 1 (bqljfrferpzkzwoxlnya)
# ============================================
# NOTA: Credenciais do Project 1 estão hardcoded em lib/api/supabase-client.js
# Esta é a instância com Service Role Key (permissões administrativas)
# URL: https://bqljfrferpzkzwoxlnya.supabase.co

# ============================================
# Supabase Project 2 (yqdqmudsnjhixtxldqwi)
# ============================================
# Usado principalmente para logging
# Obter em: Supabase Dashboard → Settings → API

# URL do projeto Supabase
SUPABASE_URL=https://yqdqmudsnjhixtxldqwi.supabase.co

# Anon Key (chave pública com Row Level Security)
SUPABASE_KEY=

# ============================================
# Postman API
# ============================================
# API do Postman para automação de collections e workflows
# Obter em: Postman → Settings → API Keys → Generate API Key

# API Key do Postman (formato: PMAK-xxx)
POSTMAN_API_KEY=

# ID do workspace principal Uniforce
POSTMAN_WORKSPACE_ID=46f8007d-550c-46e6-8a9d-729577ee3329

# ============================================
# INFORMAÇÕES IMPORTANTES
# ============================================
#
# ONDE OBTER AS CREDENCIAIS:
# --------------------------
# 1. n8n:
#    - URL: https://api.uniforce.com.br
#    - API Key: n8n → Settings → API → Create API Key
#
# 2. Cloudflare Access:
#    - Dashboard: https://one.dash.cloudflare.com/
#    - Zero Trust → Access → Service Auth → Create Service Token
#
# 3. Supabase:
#    - Dashboard: https://app.supabase.com/
#    - Project Settings → API
#
# 4. Postman:
#    - Web: https://postman.com → Settings → API Keys
#
# SEGURANÇA:
# ----------
# - NUNCA commite o arquivo .env
# - NUNCA compartilhe credenciais em texto plano
# - Rotacione credenciais periodicamente
# - Use variáveis de ambiente em produção
#
# VALIDAÇÃO:
# ----------
# Execute os testes após configurar:
#   npm run test:api              # Testa Supabase e Postman
#   node test-n8n-connection.js   # Testa n8n
#
# BACKUP:
# -------
# Mantenha um backup seguro das credenciais em local protegido
# (ex: 1Password, LastPass, Bitwarden, ou cofre seguro da empresa)
#
# ============================================
