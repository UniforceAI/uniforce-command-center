coverage/
.nyc_output/
*.lcov

# ============================================
# ARQUIVOS ESPECÍFICOS DO PROJETO
# ============================================

# Screenshots temporários (manter apenas os essenciais)
screenshots/temp/

# Downloads temporários
downloads/temp/

# Arquivos de análise local
*.local.md
TEMP_*.md

# ============================================
# SEGURANÇA
