# ============================================
# ARQUIVOS DE CONFIGURAÇÃO E CREDENCIAIS
# ============================================
# NUNCA commitar estes arquivos!

# Arquivo de ambiente com credenciais
.env
.env.local
.env.*.local

# Backups de configuração (podem conter credenciais)
backups/
*.backup
*.bak

# Logs que podem conter informações sensíveis
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# DEPENDÊNCIAS
# ============================================

# Node modules
node_modules/
npm-debug.log
yarn-error.log

