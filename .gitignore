certificates/

# Tokens e secrets
secrets/
.secrets
*.secret

# ============================================
# IMPORTANTE: ARQUIVOS QUE DEVEM SER COMMITADOS
# ============================================
# .env.example - Template de configuração (SEM credenciais)
# README.md - Documentação
# package.json - Dependências
# Código fonte - Todos os arquivos .js, .ts, etc.
